{
  "expo": {
    "name": "TTEG App",
    "slug": "tteg-app",
    "version": "1.1.0",
    "orientation": "portrait",
    "scheme": "tteg-app",
    "userInterfaceStyle": "light",
    "icon": "./assets/images/icon.png",
    "ios": {
      "supportsTablet": true,
      "buildNumber": "3"
    },
    "android": {
      "package": "com.tteg.app",
      "versionCode": 2,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "TTEG App needs camera access to capture site photos for reports."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/iit_bhilai_logo.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-secure-store",
      "expo-location"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "apiBaseUrl": "https://arohanative-1.onrender.com",
      "eas": {
        "projectId": "b61ed49b-25c8-41e1-80c2-d90180c6c467"
      }
    }
  }
}