# ==========================================
# TTEG App Backend - Environment Variables
# ==========================================

# 1. Server Configuration
# ------------------------------------------
# The port the backend will run on (Default: 3000)
PORT=3000
# The environment type (development, production)
NODE_ENV=development

# 2. Database (MongoDB)
# ------------------------------------------
# Connection string for your MongoDB database (Required)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/tteg_app?retryWrites=true&w=majority

# 3. Security (JWT)
# ------------------------------------------
# Secret key used for signing JWT tokens (Required)
JWT_SECRET=your_super_secret_jwt_key_here
# How long until the user is logged out (Default: 7d)
JWT_EXPIRES_IN=7d

# 4. File Storage (Azure Blob Storage)
# ------------------------------------------
# If this is left empty, the server will fall back to local storage in the "test_upload/" directory.
# This is recommended for local development to avoid polluting production buckets.
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<account>;AccountKey=<key>;EndpointSuffix=core.windows.net
# The container name for uploads (Default: tteg-uploads)
AZURE_STORAGE_CONTAINER_NAME=tteg-uploads
